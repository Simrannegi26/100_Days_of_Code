
Q1 (User Inputs, Operations & Output)
Write a program to input two numbers and display their sum.import java.util.Scanner;

sol-
import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int a = sc.nextInt();
        int b = sc.nextInt();

        int sum = a + b;

        System.out.println("Sum = " + sum);

        sc.close();
    }
}


